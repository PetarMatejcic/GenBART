PROJECT_NAME           = "GenBART C++ Backend"
PROJECT_BRIEF          = "C++ backend for GenBART"
OUTPUT_DIRECTORY       = _doxygen

GENERATE_HTML          = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml

RECURSIVE              = YES

INPUT                  = ../src/cpp
FILE_PATTERNS          = *.hpp *.cpp

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

QUIET                  = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
SKIP_FUNCTION_MACROS   = YES

STRIP_FROM_PATH        = ..